# Database (Docker Compose will override DATABASE_URL with the container hostname)
# If 5432 is in use on your machine, change POSTGRES_PORT and update DATABASE_URL to match
POSTGRES_PORT=5432
DATABASE_URL=postgresql://taskflow:taskflow@localhost:${POSTGRES_PORT}/taskflow

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow

# JWT — CHANGE THIS in production (minimum 32 random characters)
JWT_SECRET=BqvbnSsY5280aSIlaV2CxVcTd0uPVCl6WcYo9jP3Rcw=

# App
NODE_ENV=production
LOG_LEVEL=info
NEXT_TELEMETRY_DISABLED=1
APP_PORT=3000
